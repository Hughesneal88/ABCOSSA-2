# Google Calendar: paste the full embed `src` from Calendar → Integrate calendar
# Example: https://calendar.google.com/calendar/embed?src=YOUR_CALENDAR_ID&ctz=Africa%2FAccra
VITE_GOOGLE_CALENDAR_EMBED_URL=

# Optional: dedicated Google Form for UGLSU event proposals (defaults to general suggestion form)
# VITE_EVENT_PROPOSAL_URL=

# Optional: HTTPS URL returning JSON array of internships (defaults to /internships.json from public/)
# VITE_INTERNSHIPS_JSON_URL=

# Supabase (optional): live content + /admin staff portal (password sign-in; create users under Authentication → Users)
# Run migrations in supabase/migrations; add editor emails to content_editors
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
